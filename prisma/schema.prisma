generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Venue {
  id        String   @id @default(cuid())
  name      String
  area      String
  address   String
  mapsUrl   String
  surface   String
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  games     Game[]

  @@index([area])
}

model Game {
  id               String     @id @default(cuid())
  title            String
  date             DateTime   @db.Date
  startTime        String
  endTime          String
  venueName        String
  address          String
  mapsUrl          String
  surface          String
  priceCzk         Int
  format           String
  maxPlayers       Int        @default(18)
  subsNote         String?
  rules            String?
  organizerName    String
  manageCodeHash   String
  status           GameStatus @default(PENDING)
  reviewedAt       DateTime?
  reviewedBy       String?
  paymentAccount   String?
  paymentBankCode  String?
  paymentMessage   String?
  allowPlusOne     Boolean    @default(false)
  /// Weekly series id (e.g. mon-letna). When set, past dates auto-roll to next week with empty lists.
  seriesKey        String?
  /// 0=Sun … 6=Sat — matches Date.getUTCDay() for @db.Date storage.
  recurringWeekday Int?
  venueId          String?
  venue            Venue?     @relation(fields: [venueId], references: [id])
  signups          Signup[]
  matchResult      MatchResult?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@index([date])
  @@index([status])
  @@index([seriesKey, date])
}

/// Final score + POTM voting for a finished friendly.
model MatchResult {
  id          String      @id @default(cuid())
  gameId      String      @unique
  game        Game        @relation(fields: [gameId], references: [id], onDelete: Cascade)
  teamAName   String      @default("Team A")
  teamBName   String      @default("Team B")
  teamAScore  Int
  teamBScore  Int
  votingOpen  Boolean     @default(true)
  motmName    String?
  motmNameKey String?
  announcedAt DateTime?
  notes       String?
  goals       MatchGoal[]
  votes       MotmVote[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model MatchGoal {
  id            String      @id @default(cuid())
  matchResultId String
  matchResult   MatchResult @relation(fields: [matchResultId], references: [id], onDelete: Cascade)
  scorerName    String
  scorerNameKey String
  team          String
  minute        Int?
  createdAt     DateTime    @default(now())

  @@index([matchResultId])
  @@index([scorerNameKey])
}

model MotmVote {
  id            String      @id @default(cuid())
  matchResultId String
  matchResult   MatchResult @relation(fields: [matchResultId], references: [id], onDelete: Cascade)
  voterKey      String
  voterName     String
  playerName    String
  playerNameKey String
  createdAt     DateTime    @default(now())

  @@unique([matchResultId, voterKey])
  @@index([matchResultId])
  @@index([playerNameKey])
}

model Signup {
  id         String   @id @default(cuid())
  gameId     String
  game       Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  name       String
  guestName  String?
  listType   ListType @default(MAIN)
  position   Int
  leaveToken String   @unique
  createdAt  DateTime @default(now())

  @@unique([gameId, name])
  @@index([gameId, listType])
}

model Ban {
  id          String    @id @default(cuid())
  nameKey     String    @unique
  displayName String
  reason      String
  feeCzk      Int       @default(0)
  active      Boolean   @default(true)
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  liftedAt    DateTime?
  liftedBy    String?

  @@index([active])
}

/// Audit trail for admin insights (regulars vs flakes).
model PlayerEvent {
  id          String         @id @default(cuid())
  nameKey     String
  displayName String
  gameId      String?
  type        PlayerEventType
  createdAt   DateTime       @default(now())

  @@index([nameKey])
  @@index([type])
  @@index([createdAt])
}

enum GameStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ListType {
  MAIN
  WAITING
}

enum PlayerEventType {
  JOINED
  LEFT
  REMOVED
  BANNED
  LATE_LEAVE_BLOCKED
}
